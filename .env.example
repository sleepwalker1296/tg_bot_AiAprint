# ===== TELEGRAM =====
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321   # Через запятую ID администраторов

# ===== AI GENERATION =====
# Провайдер генерации: openai | stability | replicate
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Stability AI (альтернатива)
STABILITY_API_KEY=your_stability_api_key_here

# Replicate (альтернатива)
REPLICATE_API_TOKEN=your_replicate_token_here

# ===== МОЙСКЛАД =====
MOYSKLAD_LOGIN=your_login@example.com
MOYSKLAD_PASSWORD=your_password_here
# Или токен (предпочтительно):
MOYSKLAD_TOKEN=your_moysklad_token_here
MOYSKLAD_ORGANIZATION_ID=your_organization_uuid_here
MOYSKLAD_STORE_ID=your_store_uuid_here

# ===== ИЗОБРАЖЕНИЯ =====
# Путь к логотипу для водяного знака
WATERMARK_LOGO_PATH=assets/watermark_logo.png
WATERMARK_TEXT=AiAprint © Предпросмотр
# Степень размытия для превью (0 = без размытия, 10 = сильное)
BLUR_RADIUS=5
# Качество JPEG для превью (1-100)
PREVIEW_QUALITY=40

# ===== БАЗА ДАННЫХ =====
DATABASE_URL=sqlite:///data/bot.db

# ===== НАСТРОЙКИ БОТА =====
# Максимальный размер принимаемого фото (в байтах)
MAX_PHOTO_SIZE=20971520
# Директория для временных файлов
TEMP_DIR=temp
# Директория для сохранения заказов
ORDERS_DIR=data/orders
